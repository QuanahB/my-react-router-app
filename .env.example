# Ecommerce storefront — copy to `.env` and adjust for your machine.
# React Router / Vite only exposes variables prefixed with VITE_ to the browser.

# Browser-facing store API base URL.
# In development, leave as "/api" so Vite proxies to Flask (see vite.config.ts).
# In production, set to your deployed Flask origin, e.g. "https://api.yourstore.com".
VITE_API_BASE_URL=/api

# Server-side (SSR loader/action) absolute URL to Flask.
# Used when React Router runs fetch on Node — relative "/api" would not reach Flask.
API_URL=http://127.0.0.1:5000/api
